datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Product {
  id           String   @id @default(uuid())
  name         String
  description  String
  price        Float
  image        String
  sku          String
  availability Boolean
  createdAt    DateTime @default(now())
}